# Environment
.env
.env.*

# Corpus files — do not commit copyrighted PDFs or raw rulebook text
data/raw/
data/extracted/
data/canonical/
# SRD 3.5 chunks are OGL-licensed and safe to commit for backup and review.
# Non-SRD chunks (PHB, DMG, etc.) remain excluded. To admit additional OGL sources,
# add !data/chunks/<source_id>/ below and remove from data/chunks/* exclusion.
data/chunks/*
!data/chunks/srd_35
*.pdf
*.epub

# Vector database storage
data/index/
*.chroma/
*.faiss
*.hnswlib

# Project-local git worktrees
.worktrees/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Notebooks (checkpoints)
.ipynb_checkpoints/

# Logs and temp files
logs/
*.log
tmp/
scratch/

# OS
.DS_Store
Thumbs.db
